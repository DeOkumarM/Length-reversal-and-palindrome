#include<stdio.h>
#include<string.h>
int main()
{
    char str[1000],rev[1000];
    int i,j,count=0,c=0,n;
    /*length of string*/
    printf("Enter the string: ");
    scanf("%s",str);
    for(i=0;str[i] !='\0';++i);
    printf("Length of the string : %d",i);
    /*reversal of string*/
    while(str[count]!='\0')
    {
        count++;
    }
    j=count-1;
    for(i=0;i<count;i++)
    {
        rev[i] = str[j];
        j--;
    }
    printf("\nString After Reverse : %s",rev);
    /*palindrone*/
    n=strlen(str);
    for(i=0;i<n/2;i++)
    {
        if(str[i]==str[n-i-1]);
        c++;
    }
    if(c==i)
    printf("\nString is palindrome");
    else
    printf("\nstring is not palindrome");
    return 0;
}
